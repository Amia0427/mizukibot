MC_API_KEY=placeholder
MC_AI_MODEL=
MIZUKI_MCP_CONFIG=
MCP_DISCOVERY_MODE=lazy
MCP_WARM_ON_RUNTIME_INIT=false
MCP_SESSION_IDLE_TTL_MS=0
MIZUKI_SKILLS_DIR=
MIZUKI_SKILLS_VENV=
MIZUKI_SKILLS_PY_DEPS=
MIZUKI_SKILLS_BIN=

# ===== Diagnostics and daemon =====
ENABLE_DEBUG_LOG=true
PERF_LOG_ENABLED=false
RESOURCE_SNAPSHOT_ENABLED=false
MODEL_SELF_CHECK_TIMEOUT_MS=25000
BOT_DAEMON_MAIN_EARLY_EXIT_WINDOW_MS=900000
BOT_DAEMON_MAIN_EARLY_EXIT_MAX_RESTARTS=2
BOT_DAEMON_MAIN_EARLY_EXIT_COOLDOWN_MS=900000
RUNTIME_EXCEPTION_WINDOW_MS=300000
RUNTIME_HOTSPOT_WINDOW_MS=300000
