# NapCat 连接模式配置

# WebSocket 模式（默认）
NAPCAT_WS_URL=ws://127.0.0.1:3001
NAPCAT_WS_TOKEN=
NAPCAT_ACTION_TIMEOUT_MS=30000

# HTTP 反向连接模式（更稳定）
# 启用后将禁用 WebSocket，改为接收 NapCat 的 HTTP POST
NAPCAT_HTTP_REVERSE_ENABLED=false
NAPCAT_HTTP_REVERSE_PORT=3002

# 消息入口全链路异步调度
# 默认启用：NapCat WS/HTTP 回调只入队，不等待主回复完整链路
MESSAGE_INGRESS_ASYNC_ENABLED=true
MESSAGE_INGRESS_ASYNC_MAX_ACTIVE=64
MESSAGE_INGRESS_ASYNC_MAX_QUEUE_LENGTH=200
MESSAGE_INGRESS_ASYNC_SHUTDOWN_DRAIN_MS=15000

# 主回复模型 HTTP 传输层浏览器 TLS/JA3 指纹伪装
MODEL_TLS_IMPERSONATION_ENABLED=true
MODEL_TLS_IMPERSONATION_CLIENT=chrome
MODEL_TLS_IMPERSONATION_STREAM_ENABLED=true
MODEL_TLS_IMPERSONATION_FALLBACK_ENABLED=true
MODEL_TLS_IMPERSONATION_CONNECTION_REUSE_ENABLED=false
MODEL_TLS_IMPERSONATION_FORCE_HTTP1=false
MODEL_TLS_IMPERSONATION_INSECURE_SKIP_VERIFY=false

# 端点级 Anthropic Messages 兼容：
# a-ocnfniawgw.cn-shanghai.fcapp.run 会被代码强制走 /v1/messages，并自动带 context-1m-2025-08-07。
# 其它主回复端点不受影响，仍按 API_PROVIDER / URL 默认推断。

# Windows daemon 主 bot 短命重启保护
BOT_DAEMON_MAIN_EARLY_EXIT_WINDOW_MS=900000
BOT_DAEMON_MAIN_EARLY_EXIT_MAX_RESTARTS=2
BOT_DAEMON_MAIN_EARLY_EXIT_COOLDOWN_MS=900000

# NapCat 配置示例（OneBot 11 HTTP 反向连接）
# 在 NapCat 的 onebot11.json 中配置：
# {
#   "http": {
#     "enable": true,
#     "host": "127.0.0.1",
#     "port": 3002,
#     "secret": "",
#     "enableHeart": true,
#     "enablePost": true,
#     "postUrls": ["http://127.0.0.1:3002"]
#   }
# }
