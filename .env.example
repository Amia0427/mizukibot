# MizukiBot example environment
# Updated: 2026-06-17 19:31 +08:00
# Copy to .env and replace placeholder values. Do not commit real .env files.

# ===== Required model endpoint =====
# API_BASE_URL should point to an OpenAI-compatible /v1/chat/completions
# endpoint, Anthropic-compatible /v1/messages endpoint, or provider gateway.
API_BASE_URL=""
API_PROVIDER=""
API_KEY=placeholder
AI_MODEL=gemini-3-pro-preview
AI_TEMPERATURE=0.9
AI_TOP_P=0.92
AI_MAX_TOKENS=8192
AI_RETRIES=2
AI_STREAM_ENABLED=false
AI_STREAM_CHUNK_MS=900
AI_STREAM_FIRST_TOKEN_TIMEOUT_MS=240000
REQUEST_TIMEOUT_MS=60000
REQUEST_STREAM_TIMEOUT_MS=300000
# Set to false to disable the normal-user daily model call limit.
NORMAL_USER_MODEL_DAILY_LIMIT_ENABLED=true
NORMAL_USER_MODEL_DAILY_LIMIT=25
NORMAL_USER_MODEL_DAILY_LIMIT_STATE_FILE=""

# Optional fallback model. Keep disabled unless the fallback endpoint is verified.
AI_FALLBACK_ENABLED=false
AI_FALLBACK_MODEL=
AI_FALLBACK_PROVIDER=
AI_FALLBACK_API_BASE_URL=""
AI_FALLBACK_API_KEY=placeholder
AI_FALLBACK_FAILURE_THRESHOLD=3
AI_FALLBACK_COOLDOWN_MS=600000

# ===== Admin model override =====
ADMIN_USER_IDS=
ADMIN_API_BASE_URL=""
ADMIN_API_PROVIDER=""
ADMIN_API_KEY=placeholder
ADMIN_AI_MODEL=
ADMIN_AI_TEMPERATURE=
ADMIN_AI_TOP_P=
ADMIN_AI_MAX_TOKENS=""
ADMIN_AI_RETRIES=
ADMIN_AI_REASONING_EFFORT=
ADMIN_PRIVATE_MAIN_REPLY_STREAM_FIRST_TOKEN_TIMEOUT_MS=75000
ADMIN_PRIVATE_MAIN_REPLY_STREAM_TOTAL_TIMEOUT_MS=75000
ADMIN_AI_FALLBACK_ENABLED=false
ADMIN_AI_FALLBACK_MODEL=
ADMIN_AI_FALLBACK_PROVIDER=
ADMIN_AI_FALLBACK_API_BASE_URL=""
ADMIN_AI_FALLBACK_API_KEY=placeholder

# ===== Provider/protocol compatibility =====
OPENAI_MAIN_API_MODE=auto
OPENAI_PROMPT_CACHE_ENABLED=true
OPENAI_PROMPT_CACHE_RETENTION=
OPENAI_PROMPT_CACHE_KEY_PREFIX=""
ANTHROPIC_VERSION=2023-06-01
ANTHROPIC_BETA=
ANTHROPIC_PROMPT_CACHE_TTL=1h
ANTHROPIC_ADAPTIVE_THINKING_ENABLED=false
MODEL_TOP_P_ENABLED=false
MODEL_ENDPOINT_ALLOW_LOCAL_HTTP=false

# Browser-like TLS/JA3 impersonation for model HTTP calls.
MODEL_TLS_IMPERSONATION_ENABLED=true
MODEL_TLS_IMPERSONATION_CLIENT=chrome
MODEL_TLS_IMPERSONATION_STREAM_ENABLED=true
MODEL_TLS_IMPERSONATION_FALLBACK_ENABLED=true
MODEL_TLS_IMPERSONATION_CONNECTION_REUSE_ENABLED=false
MODEL_TLS_IMPERSONATION_FORCE_HTTP1=false
MODEL_TLS_IMPERSONATION_INSECURE_SKIP_VERIFY=false

# ===== NapCat / OneBot (HTTP only) =====
NAPCAT_ACTION_TIMEOUT_MS=30000

# Bot posts OneBot actions to NapCat over HTTP.
NAPCAT_HTTP_API_BASE_URL=placeholder
NAPCAT_HTTP_ACTION_SECRET=placeholder

# HTTP reverse ingress: configure NapCat onebot11 postUrls to
# http://127.0.0.1:3002 and use the same secret above.
NAPCAT_HTTP_REVERSE_PORT=3002
BOT_QQ=
QQ_THINKING_EMOJI_IDS=355
QQ_THINKING_EMOJI_TIMEOUT_MS=3000
QQ_SAFETY_RESTRICTION_EMOJI_IDS=39

# ===== Web panel =====
WEB_PORT=3005
WEB_BIND_HOST=127.0.0.1
WEB_TOKEN=placeholder
WEB_LOCAL_ONLY_WITHOUT_TOKEN=true

# ===== Runtime paths and process mode =====
TIMEZONE=Asia/Shanghai
DATA_DIR=
PROMPTS_DIR=
LOW_RESOURCE_MODE=false
MIZUKIBOT_RUNTIME_ROLE=main
BOT_MAIN_HEARTBEAT_ENABLED=true
BOT_MAIN_HEARTBEAT_INTERVAL_MS=30000
DATA_TMP_CLEANUP_ENABLED=true
DATA_TMP_CLEANUP_MAX_AGE_MS=86400000

# ===== Concurrency / queue controls =====
MESSAGE_INGRESS_ASYNC_ENABLED=true
MESSAGE_INGRESS_ASYNC_MAX_ACTIVE=64
MESSAGE_INGRESS_ASYNC_MAX_QUEUE_LENGTH=200
MESSAGE_INGRESS_ASYNC_SHUTDOWN_DRAIN_MS=15000
INBOUND_GLOBAL_MAX_CONCURRENCY=3
INBOUND_GENERAL_MAX_CONCURRENCY=2
INBOUND_ADMIN_MAX_CONCURRENCY=1
INBOUND_PER_USER_MAX_INFLIGHT=1
PRIVATE_INBOUND_GLOBAL_MAX_CONCURRENCY=1
PRIVATE_INBOUND_GENERAL_MAX_CONCURRENCY=0
PRIVATE_INBOUND_ADMIN_MAX_CONCURRENCY=1
PRIVATE_INBOUND_PER_USER_MAX_INFLIGHT=1
FOREGROUND_GLOBAL_MAX_CONCURRENCY=10
FOREGROUND_ADMIN_RESERVED_SLOTS=1
FOREGROUND_PER_USER_MAX_INFLIGHT=1

# ===== Continuous message aggregation =====
CONTINUOUS_MESSAGE_ENABLED=true
CONTINUOUS_MESSAGE_DEBOUNCE_MS=10000
CONTINUOUS_MESSAGE_GROUP_PLAIN_TEXT_DEBOUNCE_MS=2000
CONTINUOUS_MESSAGE_AT_BOT_DEBOUNCE_MS=5000
CONTINUOUS_MESSAGE_PRIVATE_DEBOUNCE_MS=5000
CONTINUOUS_MESSAGE_MAX_HOLD_MS=12000
CONTINUOUS_MESSAGE_REPLY_EXPANSION_ENABLED=true
CONTINUOUS_MESSAGE_FORWARD_EXPANSION_ENABLED=true
CONTINUOUS_MESSAGE_QQ_CARD_LINKS_ENABLED=true
CONTINUOUS_MESSAGE_LINK_ENRICH_ENABLED=false

# ===== Routing / planner / tools =====
ENABLE_AI_ROUTER=false
AI_ROUTER_BASE_URL=
AI_ROUTER_API_KEY=placeholder
AI_ROUTER_MODEL=
DIRECT_CHAT_PLANNER_ENABLED=false
PLAN_API_BASE_URL=""
PLAN_API_KEY=placeholder
PLAN_MODEL=gpt-5.4-mini
PLAN_REASONING_EFFORT=off
PLANNER_REQUEST_TIMEOUT_MS=15000
PLANNER_API_MODE=""
GLOBAL_TOOLS_ENABLED=true
GLOBAL_TOOLS_API_BASE_URL=""
GLOBAL_TOOLS_API_KEY=placeholder
GLOBAL_TOOLS_MODEL=
GLOBAL_TOOLS_MAX_CALLS_PER_TURN=4
TOOL_TIMEOUT_MS=10000
AMAP_KEY=placeholder
LOCAL_COMMAND_BRIDGE_ENABLED=true
LOCAL_COMMAND_BRIDGE_URL=http://127.0.0.1:3210
LOCAL_COMMAND_BRIDGE_TOKEN=placeholder

# ===== Image, memory and recall models =====
MEMORY_MODEL=gemini-3-pro-preview
MEMORY_API_BASE_URL=""
MEMORY_API_KEY=placeholder
IMAGE_MODEL=gemini-3-pro-preview
IMAGE_API_BASE_URL=""
IMAGE_API_KEY=placeholder
IMAGE_MODEL_TIMEOUT_MS=18000
IMAGE_MODEL_INPUT_TOKEN_WARN_THRESHOLD=18000
IMAGE_MODEL_INPUT_TOKEN_HARD_LIMIT=20000
VISION_CAPTION_WORKER_ENABLED=false
VISION_CAPTION_WORKER_API_BASE_URL=""
VISION_CAPTION_WORKER_API_KEY=placeholder
VISION_CAPTION_WORKER_MODEL=
IMAGE_MEMORY_VISUAL_SUMMARY_ENABLED=true
IMAGE_MEMORY_VISUAL_SUMMARY_API_BASE_URL=""
IMAGE_MEMORY_VISUAL_SUMMARY_API_KEY=placeholder
IMAGE_MEMORY_VISUAL_SUMMARY_MODEL=
IMAGE_MEMORY_VISUAL_SUMMARY_TIMEOUT_MS=25000
MEMORY_LEARNING_ENABLED=true
MEMORY_V3_ENABLED=true
MEMORY_RAG_ENABLED=true
MEMORY_HYBRID_RECALL_ENABLED=true
MEMORY_EMBEDDING_ENABLED=false
MEMORY_EMBEDDING_MODEL=
MEMORY_EMBEDDING_API_BASE_URL=""
MEMORY_EMBEDDING_API_KEY=placeholder
MEMORY_VECTOR_STORE=local_jsonl
MEMORY_LANCEDB_READ_ENABLED=false
MEMORY_LANCEDB_SYNC_ENABLED=true
MEMORY_RERANK_ENABLED=true
MEMORY_RERANK_MODEL=
MEMORY_RERANK_API_BASE_URL=""
MEMORY_RERANK_API_KEY=placeholder
MEMORY_RETRIEVAL_SOFT_BUDGET_MS=300
MAIN_PROMPT_MEMORY_CONTEXT_MAX_TOKENS=2500
SHORT_TERM_MEMORY_MAX_TOKENS=120000
SHORT_TERM_MEMORY_RECENT_MESSAGES=240
SHORT_TERM_MEMORY_RECENT_TURNS=48

# ===== MemOS / OpenViking optional remote memory =====
MEMOS_MCP_ENABLED=false
MEMOS_REMOTE_RECALL_ENABLED=false
MEMOS_API_KEY=placeholder
MEMOS_USER_ID=
MEMOS_CHANNEL=MODELSCOPE
MEMOS_KB_IDS=
OPENVIKING_ENABLED=false
OPENVIKING_INGEST_ENABLED=false
OPENVIKING_RECALL_ENABLED=false
OPENVIKING_BASE_URL=http://localhost:1933
OPENVIKING_API_KEY=placeholder
OPENVIKING_ADMIN_API_KEY=placeholder
OPENVIKING_ACCOUNT_ID=
OPENVIKING_AGENT_ID=mizukibot

# ===== Passive awareness / proactive behavior =====
PASSIVE_AWARENESS_ENABLED=false
PASSIVE_AWARENESS_GROUP_IDS=
PASSIVE_AWARENESS_API_BASE_URL=""
PASSIVE_AWARENESS_API_KEY=placeholder
PASSIVE_AWARENESS_MODEL=
PASSIVE_AWARENESS_REPLY_API_BASE_URL=""
PASSIVE_AWARENESS_REPLY_API_KEY=placeholder
PASSIVE_AWARENESS_REPLY_MODEL=
PASSIVE_AWARENESS_TIMEOUT_MS=15000
PASSIVE_AWARENESS_REPLY_TIMEOUT_MS=20000
INITIATIVE_POLICY_ENABLED=true
INITIATIVE_DECISION_ENABLED=true
INITIATIVE_DECISION_API_BASE_URL=""
INITIATIVE_DECISION_API_KEY=placeholder
INITIATIVE_DECISION_MODEL=
PROACTIVE_REPLY_ENABLED=false
PROACTIVE_GREETING_FALLBACK_ENABLED=false

# ===== Post-reply worker / background learning =====
POST_REPLY_WORKER_ENABLED=false
POST_REPLY_WORKER_INLINE=false
POST_REPLY_WORKER_CONCURRENCY=1
POST_REPLY_WORKER_RSS_RECYCLE_MB=0
POST_REPLY_ENRICH_ENABLED=true
POST_REPLY_VECTOR_MAINTENANCE_ENABLED=true
POST_REPLY_VECTOR_WATCHDOG_ENABLED=true
POST_REPLY_FAILED_TRANSIENT_REQUEUE_ENABLED=false

# ===== Optional content features =====
NORMAL_FAST_REPLY_ENABLED=false
HUMANIZER_AGENT_ENABLED=true
HUMANIZER_FORCE_NON_STREAM=true
HUMANIZER_AGENT_API_BASE_URL=""
