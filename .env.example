REFUSAL_AGENT_API_BASE_URL=""
REFUSAL_AGENT_API_KEY=placeholder
REFUSAL_AGENT_MODEL=gpt-5.4-mini
CREATE_AGENT_ENABLED=false
CREATE_AGENT_API_BASE_URL=""
CREATE_AGENT_API_KEY=placeholder
CREATE_AGENT_MODEL=gpt-image-1.5
CREATE_AGENT_DAILY_LIMIT=20
DAILY_SHARE_ENABLED=false
QZONE_AUTO_PUBLISH_ENABLED=false
QZONE_HUMANIZE_PUBLISH_DELAY_ENABLED=true
QZONE_HUMANIZE_PUBLISH_DELAY_MIN_MS=8000
QZONE_HUMANIZE_PUBLISH_DELAY_MAX_MS=35000
QZONE_COOKIE=
QZONE_UIN=
BOT_DIARY_QZONE_IMAGE_ENABLED=false
BOT_DIARY_QZONE_IMAGE_PROVIDER_API_BASE_URL=""
BOT_DIARY_QZONE_IMAGE_PROVIDER_API_KEY=placeholder
BOT_DIARY_QZONE_IMAGE_PROVIDER_MODEL=

# ===== Optional integrations =====
PRIVATE_CHAT_TEST_USER_IDS=
PRIVATE_CHAT_ALLOWED_USER_IDS=
REFUSE_BYPASS_USER_IDS=
TG_ENABLE=false
TG_BOT_TOKEN=placeholder
TG_ALLOWED_CHAT_IDS=
MC_ENABLED=false
MC_HOST=127.0.0.1
MC_PORT=25565
MC_USERNAME=mizuki-bot
MC_AUTH=offline
MC_PASSWORD=placeholder
