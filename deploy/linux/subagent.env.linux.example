# Copy selected values into .env when you want to enable an external child agent.
# All tool-style routes are forwarded to the child agent.
# Mizuki keeps normal chat locally, reviews the child-agent result, then sends it back to QQ.

SUBAGENT_ENABLED=true
SUBAGENT_BACKEND=openclaw
SUBAGENT_NAME=openclaw
# Legacy compatibility field. Current tool-style routes are forwarded once the bridge is enabled.
SUBAGENT_ROUTE_MIN_CONFIDENCE=0.62
SUBAGENT_REVIEW_ENABLED=true
SUBAGENT_TIMEOUT_MS=120000

# OpenClaw backend on the same Linux server.
# Recommended when you want every tool task to run in OpenClaw and return to Mizuki for review.
OPENCLAW_COMMAND=/www/server/nodejs/v24.14.1/bin/node
OPENCLAW_BASE_ARGS=["/www/server/nodejs/v24.14.1/lib/node_modules/openclaw/openclaw.mjs"]
OPENCLAW_WORKDIR=/root/.openclaw/workspace
OPENCLAW_AGENT_ID=main
OPENCLAW_TIMEOUT_MS=180000
OPENCLAW_VERBOSE=off
OPENCLAW_THINKING=off
OPENCLAW_JSON_OUTPUT=true

# If you want to switch to a generic command-based child agent, use:
# SUBAGENT_BACKEND=command
# SUBAGENT_NAME=my-subagent
# SUBAGENT_COMMAND=python3
# SUBAGENT_WORKDIR=/opt/my-subagent
# SUBAGENT_ARGS=["-m","your_agent_cli","run","--session","{sessionId}","--message","{message}"]
