const config = require('../config');
const { postWithRetry } = require('../api/httpClient');
const { extractMessageContent, extractJsonSafely } = require('../api/parser');
const {
  appendGroupMessage,
  getRecentMessages,
  getLastAwarenessAt,
  setLastAwarenessAt,
  getGlobalLastAwarenessAt,
  getLastReplyAt,
  canReplyInHour,
  recordReply
} = require('../utils/groupAwarenessState');

function normalizeText(value) {
  return String(value || '').replace(/\s+/g, ' ').trim();
}

function ensureChatCompletionsUrl(url) {
  const raw = String(url || '').replace(/\/+$/, '');
  if (/\/chat\/completions$/i.test(raw)) return raw;
  if (/\/v\d+$/i.test(raw)) return `${raw}/chat/completions`;
  return raw;
}

function isEnabledForGroup(groupId) {
  if (!config.PASSIVE_AWARENESS_ENABLED) return false;
  const groups = Array.isArray(config.PASSIVE_AWARENESS_GROUP_IDS)
    ? config.PASSIVE_AWARENESS_GROUP_IDS
    : [];
  if (groups.length === 0) return false;
  return groups.includes(String(groupId || '').trim());
}

function getSenderName(msg = {}) {
  return String(
    msg.sender?.card
      || msg.sender?.nickname
      || msg.sender?.nick
      || msg.user_id
      || ''
  ).trim();
}

function isNoiseText(text = '') {
  const t = normalizeText(text);
  if (!t) return true;
  if (/^\[CQ:[^\]]+\]$/.test(t)) return true;
  if (/^[\p{P}\p{S}\s]+$/u.test(t)) return true;
  if (/^(哈哈+|hhh+|6{2,}|草+|啊+|哦+|嗯+|表情|收到)$/i.test(t)) return true;
  return false;
}

function containsBotTopic(text = '') {
  const t = normalizeText(text).toLowerCase();
  if (!t) return false;
  return /(机器人|bot|瑞希|ai|模型|回复|插件|接入|napcat|qq机器人|监听|群聊)/i.test(t);
}

function containsQuestionSignal(text = '') {
  const t = normalizeText(text);
  if (!t) return false;
  return /[?？]|(吗|咋|怎么|如何|是不是|能不能|行不行|为什么|啥意思|怎么做)/.test(t);
}

function scoreMessageTrigger(text = '', recentMessages = []) {
  const t = normalizeText(text);
  let score = 0;

  if (containsBotTopic(t)) score += 45;
  if (containsQuestionSignal(t)) score += 20;
  if (/(大家|你们|谁|有人|bot|机器人)/i.test(t)) score += 8;
  if (t.length >= 12) score += 5;

  const recentText = recentMessages
    .slice(-6)
    .map((item) => normalizeText(item.text))
    .join('\n');
  if (containsBotTopic(recentText)) score += 12;

  if (isNoiseText(t)) score -= 40;
  return score;
}

function buildPrompt({ groupId, senderName, recentMessages, text, score }) {
  const contextLines = recentMessages
    .slice(-12)
    .map((item) => {
      const name = normalizeText(item.sender_name) || item.sender_id || 'unknown';
      return `${name}: ${normalizeText(item.text)}`;
    })
    .filter(Boolean)
    .join('\n');

  return [
    '你在QQ群里旁听，不是被明确点名。',
    '你是晓山瑞希，要用可爱的语气自然地插话回复，可以使用颜文字。',
    '你的任务是判断此刻是否应该自然插一句话。',
    '硬规则：',
    '1. 不要抢话，不要打断高速连续对话。',
    '2. 不要连续追问，不要主导话题。',
    '3. 如果不该回复，should_reply=false 且 reply=""。',
    '4. 如果该回复，reply 必须自然、克制、口语化，控制在30字内。',
    '5. 只输出 JSON，不要输出解释。',
    '',
    `群号: ${String(groupId || '')}`,
    `当前发送者: ${senderName || 'unknown'}`,
    `本地规则分数: ${Number(score || 0)}`,
    '',
    '[最近群聊上下文]',
    contextLines || '(empty)',
    '',
    '[当前消息]',
    text || '(empty)',
    '',
    '输出格式：',
    '{"should_reply":false,"confidence":0.0,"reply":"","reason":"..."}'
  ].join('\n');
}

function parseDecision(rawText = '') {
  const obj = extractJsonSafely(String(rawText || '').trim());
  if (!obj || typeof obj !== 'object') {
    return {
      shouldReply: false,
      confidence: 0,
      reply: '',
      reason: 'invalid-json'
    };
  }

  return {
    shouldReply: Boolean(obj.should_reply),
    confidence: Number(obj.confidence || 0),
    reply: normalizeText(obj.reply || ''),
    reason: normalizeText(obj.reason || '')
  };
}

async function invokeAwarenessModel({ groupId, senderName, recentMessages, text, score }) {
  const baseUrl = ensureChatCompletionsUrl(config.PASSIVE_AWARENESS_API_BASE_URL);
  const apiKey = String(config.PASSIVE_AWARENESS_API_KEY || '').trim();
  const model = String(config.PASSIVE_AWARENESS_MODEL || '').trim();
  if (!baseUrl || !apiKey || !model) {
    return {
      shouldReply: false,
      confidence: 0,
      reply: '',
      reason: 'missing-awareness-model-config'
    };
  }

  const prompt = buildPrompt({ groupId, senderName, recentMessages, text, score });
  const resp = await postWithRetry(
    baseUrl,
    {
      model,
      temperature: Number(config.PASSIVE_AWARENESS_TEMPERATURE || 0.4),
      top_p: Number(config.PASSIVE_AWARENESS_TOP_P || 0.9),
      messages: [
        { role: 'system', content: '你是群聊旁听决策器，只输出 JSON。' },
        { role: 'user', content: prompt }
      ],
      max_tokens: Math.max(120, Number(config.PASSIVE_AWARENESS_MAX_TOKENS || 300)),
      stream: false,
      __timeoutMs: Math.max(1000, Number(config.PASSIVE_AWARENESS_TIMEOUT_MS || 15000)),
      __trace: {
        source: 'passive_awareness',
        phase: 'awareness',
        purpose: 'group_passive_decision',
        routeType: 'passive_awareness',
        userId: ''
      }
    },
    Math.max(0, Number(config.PASSIVE_AWARENESS_RETRIES || 1)),
    apiKey
  );

  const msg = extractMessageContent(resp);
  return parseDecision(msg?.content || '');
}

async function handlePassiveGroupAwareness({
  msg,
  sendGroupReply
}) {
  const groupId = String(msg.group_id || '').trim();
  const senderId = String(msg.user_id || '').trim();
  const senderName = getSenderName(msg);
  const rawText = String(msg.raw_message || '');
  const text = normalizeText(rawText.replace(/\[CQ:[^\]]+\]/g, ' '));
  const now = Date.now();

  if (!isEnabledForGroup(groupId)) return { handled: false, reason: 'group-disabled' };
  if (!text) {
    appendGroupMessage(groupId, { sender_id: senderId, sender_name: senderName, text, timestamp: now }, config.PASSIVE_AWARENESS_CONTEXT_SIZE);
    return { handled: false, reason: 'empty-text' };
  }

  appendGroupMessage(groupId, {
    sender_id: senderId,
    sender_name: senderName,
    text,
    timestamp: now
  }, config.PASSIVE_AWARENESS_CONTEXT_SIZE);

  const minLength = Math.max(1, Number(config.PASSIVE_AWARENESS_MIN_MESSAGE_LENGTH || 6));
  if (text.length < minLength || isNoiseText(text)) {
    return { handled: false, reason: 'noise-or-too-short' };
  }

  const recentMessages = getRecentMessages(groupId);
  const score = scoreMessageTrigger(text, recentMessages);
  if (score < Number(config.PASSIVE_AWARENESS_MIN_TRIGGER_SCORE || 60)) {
    return { handled: false, reason: 'score-too-low', score };
  }

  const groupLastAwarenessAt = getLastAwarenessAt(groupId);
  const globalLastAwarenessAt = getGlobalLastAwarenessAt();
  const minIntervalMs = Math.max(0, Number(config.PASSIVE_AWARENESS_MIN_INTERVAL_MS || 180000));
  const globalMinIntervalMs = Math.max(0, Number(config.PASSIVE_AWARENESS_GLOBAL_MIN_INTERVAL_MS || 15000));
  if (groupLastAwarenessAt && now - groupLastAwarenessAt < minIntervalMs) {
    return { handled: false, reason: 'group-awareness-cooldown', score };
  }
  if (globalLastAwarenessAt && now - globalLastAwarenessAt < globalMinIntervalMs) {
    return { handled: false, reason: 'global-awareness-cooldown', score };
  }

  setLastAwarenessAt(groupId, now);

  let decision;
  try {
    decision = await invokeAwarenessModel({
      groupId,
      senderName,
      recentMessages,
      text,
      score
    });
  } catch (e) {
    console.error('[group-awareness] model call failed:', e.message);
    return { handled: false, reason: 'model-call-failed', score };
  }

  if (!decision.shouldReply || !decision.reply) {
    return { handled: false, reason: decision.reason || 'model-skip', score, decision };
  }

  const replyCooldownMs = Math.max(0, Number(config.PASSIVE_AWARENESS_REPLY_COOLDOWN_MS || 300000));
  const lastReplyAt = getLastReplyAt(groupId);
  if (lastReplyAt && now - lastReplyAt < replyCooldownMs) {
    return { handled: false, reason: 'reply-cooldown', score, decision };
  }

  if (!canReplyInHour(groupId, now, config.PASSIVE_AWARENESS_MAX_REPLIES_PER_HOUR)) {
    return { handled: false, reason: 'reply-hour-limit', score, decision };
  }

  const sent = await sendGroupReply({
    groupId,
    senderId,
    replyText: decision.reply,
    atSender: Boolean(config.PASSIVE_AWARENESS_AT_SENDER),
    retries: 1,
    waitMs: 300
  });

  if (!sent) {
    return { handled: false, reason: 'send-failed', score, decision };
  }

  recordReply(groupId, now);
  return {
    handled: true,
    reason: 'replied',
    score,
    decision
  };
}

module.exports = {
  handlePassiveGroupAwareness,
  isEnabledForGroup,
  scoreMessageTrigger,
  parseDecision,
  buildPrompt,
  isNoiseText
};
