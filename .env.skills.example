# Optional env vars for native skills that still rely on external providers.
# Copy only the keys you need into .env and keep real secrets out of git.

# skill_image_generate_pro
# Preferred dedicated key. If omitted, the skill will also reuse
# BOT_DIARY_QZONE_IMAGE_PROVIDER_API_KEY when that provider is already configured.
GEMINI_API_KEY=

# skill_ppt_generate / skill_ppt_theme_list
# API key used as Bearer token when calling your own PPT HTTP adapter.
BAIDU_API_KEY=
# Your PPT adapter endpoint. The current native skill expects a POST JSON API.
BAIDU_PPT_API_URL=

# skill_youtube_transcript
# HTTP endpoint that accepts ?videoId=... and returns transcript text/XML/JSON.
YOUTUBE_TRANSCRIPT_PROVIDER_URL=

# Optional market data fallbacks already supported by native stock skills.
TWELVEDATA_API_KEY=
ALPHAVANTAGE_API_KEY=

# Local command bridge hardening
# Keep real values in .env only. If omitted, the bridge keeps localhost-only
# compatibility mode and prints a warning at startup.
LOCAL_COMMAND_BRIDGE_TOKEN=
# Optional token forwarded to local HAPI CLI calls. Do not hard-code it in code.
CLI_API_TOKEN=

# Web console hardening
# If omitted, the console keeps localhost-only compatibility mode and prints a warning.
WEB_TOKEN=

# Read-only security diagnostics
# Run with: npm run diag:security
# JSON output for automation: node scripts/diagnose-security.js --json
